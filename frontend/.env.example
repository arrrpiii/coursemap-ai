# Copy this file to `.env.local` and adjust as needed.
# Vite reads variables prefixed with VITE_.

# Production backend URL. When unset, the frontend falls back to `/api`,
# which Vite proxies to http://localhost:8000 in dev (see vite.config.js).
# Example:
#   VITE_API_URL=https://coursemap-ai-backend.onrender.com
